#cloud-config
autoinstall:
  automatic:
    reboot: true
    updates: false
    upgrade: false
  locale: en_US.UTF-8
  timezone: Asia/Shanghai
  console: |
    type=serial
    rich-mode=true
  refresh-installer:
    update: false
  apt:
    disable_components: []
    preserve_sources_list: false
    mirror-selection:
      primary:
        - country-mirror
        - uri: "http://mirrors.tuna.tsinghua.edu.cn/ubuntu"
          arches: [i386, amd64]
        - uri: "http://mirrors.tuna.tsinghua.edu.cn/ubuntu-ports"
          arches: [s390x, arm64, armhf, powerpc, ppc64el, riscv64]
    fallback: offline-install
    geoip: true
  drivers:
    install: false
  identity:
    hostname: ubuntu
    username: kdev
    password: "$6$le8Tsrwn14s46Axh$tD2pc/OSVm5Y85179nb7Uy9cioKP6UGEkIQ.cWXOiiAIVF3n/jBJwAap14S9msBJM.ciCXG4LOe27Lb2dE.zA1"
  kernel:
    package: linux-generic
  keyboard:
    layout: us
    toggle: "shift_caps_toggle"
    variant: ''
  locale: "en_US.UTF-8"
  network:
    ethernets:
      enp1s0:
        dhcp4: true
    version: 2
  ssh:
    allow-pw: true
    authorized-keys: []
    install-server: true
  packages:
    - vim
    - sudo
    - openssh-server
    - curl
    - wget
    - git
  storage:
    swap:
      size: 0
    layout:
      name: direct
  late-commands:
    - echo 'kdev ALL=(ALL) NOPASSWD:ALL' > /target/etc/sudoers.d/kdev
    - sed -i '/^GRUB_CMDLINE_LINUX/c\GRUB_CMDLINE_LINUX="net.ifnames=0 biosdevname=0 panic=5 level=10 console=ttyS0"' /target/etc/default/grub
    - curtin in-target -- update-grub2
    - 'sed -i "s/^#Port 22/Port 22/g" /target/etc/ssh/sshd_config'
    - 'sed -i "/^#PermitRootLogin/c\PermitRootLogin yes" /target/etc/ssh/sshd_config'
    - 'sed -i "/^#PubkeyAuthentication/c\PubkeyAuthentication yes" /target/etc/ssh/sshd_config'
    - 'sed -i "/^#AllowAgentForwarding/c\AllowAgentForwarding yes" /target/etc/ssh/sshd_config'
    - |
      cat > /target/etc/netplan/51-network-init.yaml <<EOF
      network:
        version: 2
        ethernets:
          all-eth:
            match:
              name: '*'
            dhcp4: true
            dhcp6: false
      EOF
    - shutdown -h now
  shutdown: poweroff
  version: 1


