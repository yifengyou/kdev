#cloud-config
autoinstall:
  automatic:
    reboot: false
    updates: false
    upgrade: false
  console: |
    type=serial
    rich-mode=true
  refresh-installer:
    update: false
  apt:
    disable_components: []
    disable_suites: [security]
    geoip: true
    preserve_sources_list: false
    primary:
      - arches:
          - amd64
        uri: http://archive.ubuntu.com/ubuntu
      - arches:
          - arm64
        uri: http://ports.ubuntu.com/ubuntu-ports
    fallback: offline-install
  drivers:
    install: false
  identity:
    hostname: ubuntu
    username: kdev
    # passwrod plain: linux
    password: "$6$le8Tsrwn14s46Axh$tD2pc/OSVm5Y85179nb7Uy9cioKP6UGEkIQ.cWXOiiAIVF3n/jBJwAap14S9msBJM.ciCXG4LOe27Lb2dE.zA1"
  keyboard:
    layout: us
    toggle: "shift_caps_toggle"
    variant: ''
  locale: en_US.UTF-8
  timezone: Asia/Shanghai
  ssh:
    allow-pw: true
    authorized-keys: []
    install-server: true
  packages:
    - vim
    - sudo
    - openssh-server
    - wget
    - curl
    - git
  storage:
    swap:
      size: 0
    layout:
      name: direct
  late-commands:
    - |
      sed -i '/^GRUB_CMDLINE_LINUX/c\GRUB_CMDLINE_LINUX="net.ifnames=0 biosdevname=0 panic=5 level=10 console=ttyS0"' /target/etc/default/grub
      curtin in-target -- update-grub2
      echo 'kdev ALL=(ALL) NOPASSWD:ALL' > /target/etc/sudoers.d/kdev
      sed -i "/^#Port 22/c\Port 22" /target/etc/ssh/sshd_config
      sed -i "/^#PermitRootLogin/c\PermitRootLogin yes" /target/etc/ssh/sshd_config
      sed -i "/^#PubkeyAuthentication/c\PubkeyAuthentication yes" /target/etc/ssh/sshd_config
      sed -i "/^#AllowAgentForwarding/c\AllowAgentForwarding yes" /target/etc/ssh/sshd_config
      cat > /target/etc/netplan/51-network-init.yaml <<EOF
      network:
        version: 2
        ethernets:
          all-eth:
            match:
              name: '*'
            dhcp4: true
            dhcp6: false
      EOF
      systemctl poweroff --force
  version: 1
  shutdown: poweroff

